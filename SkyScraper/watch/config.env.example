# skyscraper_watch config
# Paste your Discord channel webhook URL here, then the next run will push alerts.
# Create one in Discord: Channel → Edit → Integrations → Webhooks → New Webhook → Copy URL
# Until this is set, changes are still detected and written to watch.log (no push).
#
# Copy this file to config.env and fill in the value. config.env is gitignored
# so the real webhook never gets committed.
WEBHOOK_URL=
