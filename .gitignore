# ===========================================
# Master Haven - GitHub .gitignore
# ===========================================

# -----------------
# EXCLUDED FOLDERS
# -----------------
# Keeper Discord Bot - maintained separately
keeper-discord-bot-main/
keeper-discord-bot-main.zip

# Travelers Collective - separate project with its own repo
Travelers-Collective/

# Haven Trading Engine - BTC trading bot, not part of the Haven platform
trade-engine/

# Glyph YOLO training data - large dataset, not needed in repo
docs/glyph_training/


# -----------------
# ENVIRONMENT & SECRETS
# -----------------
.env
*.env.local
.env.*.local
secrets/
credentials/
creds.json
*-service-account*.json

# -----------------
# PYTHON
# -----------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.env/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytest_cache/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# -----------------
# NODE.JS / REACT
# -----------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs - Docker rebuilds frontend at container build time
Haven-UI/dist/

# -----------------
# IDE & EDITORS
# -----------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# Claude Code
.claude/

# CLAUDE.md documentation (private/local only)
CLAUDE.md
**/CLAUDE.md

# -----------------
# OS FILES
# -----------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------
# LOGS
# -----------------
*.log
logs/
Haven-UI/logs/
NMS-Save-Watcher/logs/

# -----------------
# DATABASE & USER DATA FILES
# -----------------
# Exclude user databases (contain personal discovery data)
# Be specific to avoid excluding required data files
Haven-UI/data/*.db
Haven-UI/data/*.db.backup
Haven-UI/data/backups/
Haven-UI/data/data.json
Haven-UI/backend/data/*.db
Haven-UI/backend/data/*.db.backup
NMS-Save-Watcher/data/watcher.db
!Haven-UI/data/.gitkeep

# Keep schema/example data files
!**/schema.sql
!**/example_data.json

# IMPORTANT: NMS-Save-Watcher/data/*.json files ARE required (galaxy names, mappings)
# They are NOT excluded - only watcher.db is excluded

# -----------------
# CACHE & TEMP
# -----------------
*.tmp
*.temp
.cache/
*.bak

# -----------------
# POSTER CACHE
# -----------------
# Auto-generated by services/poster_service.py — these regenerate on demand
# whenever an OG poster is requested. Checking them in pollutes commits with
# 200+ binary files that change every time a poster TTL expires.
Haven-UI/data/posters/atlas_thumb/
Haven-UI/data/posters/region_thumb/
Haven-UI/data/posters/system_thumb/
Haven-UI/data/posters/landing_og/
Haven-UI/data/posters/og_site/
Haven-UI/data/posters/og_community/
Haven-UI/data/posters/og_atlas/
Haven-UI/data/posters/og_system/
Haven-UI/data/posters/voyager_og/
Haven-UI/data/posters/voyager/
Haven-UI/data/posters/poster_cache/
# Vite dev cache — purely local build artifact
.vite/

# -----------------
# PHOTOS & UPLOADS
# -----------------
# User-uploaded discovery photos
Haven-UI/photos/*
!Haven-UI/photos/.gitkeep

# -----------------
# NMS GAME DATA
# -----------------
# NMS save files (should never be committed)
*.hg
save*.hg

# Extraction outputs
Documents/Haven-Extractor/

# -----------------
# CONFIG FILES WITH SECRETS
# -----------------
# Keep example configs, exclude real ones with secrets
config.json
NMS-Save-Watcher/config.json
!config.example.json

# -----------------
# MISC
# -----------------
*.map
flamegraph.html
.netlify/
.vercel/
Haven-UI/.env.backup
*.env.backup

# -----------------
# NMS-HAVEN-EXTRACTOR DEVELOPMENT FILES
# -----------------
# These contain hardcoded paths for local development
# Only dist/HavenExtractor should be distributed to users
NMS-Haven-Extractor/RUN_SCANNER.bat
NMS-Haven-Extractor/INSTALL_EXTRACTOR.bat
NMS-Haven-Extractor/SETUP_PYMHF.bat
NMS-Haven-Extractor/RUN_DEBUG_TEST.bat
NMS-Haven-Extractor/ANALYZE_DUMP.bat
NMS-Haven-Extractor/logs/
NMS-Haven-Extractor/haven_extractor_mod/
NMS-Haven-Extractor/archive/

# -----------------
# NMS-DEBUG-ENABLER ANALYSIS FILES
# -----------------
# Large binary analysis outputs (14MB+ symbol dumps, string extractions)
NMS-Debug-Enabler/analysis/
NMS-Debug-Enabler/*.log
